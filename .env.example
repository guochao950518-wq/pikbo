# --- Video generation (ByteDance Seedance via fal.ai) ---
# Get a key at https://fal.ai/dashboard/keys
# Without this, the app runs in validation mode (cached PIKBO Lab clip, 0 charge).
FAL_KEY=
# Public HTTPS callback used by fal queue jobs.
# FAL_WEBHOOK_URL=https://preview.example.com/api/webhooks/fal
# GENERATION_TIMEOUT_MS=1200000

# Optional analytics. Unset means zero tracking requests.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Defaults (ByteDance Seedance — do not need to set unless overriding):
# Paid:  bytedance/seedance-2.0/image-to-video
# Free:  bytedance/seedance-2.0/fast/image-to-video
# FAL_MODEL=bytedance/seedance-2.0/image-to-video
# FAL_MODEL_FREE=bytedance/seedance-2.0/fast/image-to-video
#
# Older Seedance 1.0 Pro (also ByteDance) if you prefer:
# FAL_MODEL=fal-ai/bytedance/seedance/v1/pro/image-to-video


# --- Session / credits (signed cookie) ---
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# --- Durable product data (required for live generation and production billing) ---
# Run supabase/migrations/202607220001_product_foundation.sql first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# SUPABASE_ASSETS_BUCKET=pikbo-assets
# NEXT_PUBLIC_SITE_URL=https://preview.example.com

# --- Stripe billing ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_CREATOR=price_...
# STRIPE_PRICE_SHOP=price_...
# Annual prices are optional. The annual toggle stays hidden until both exist.
# STRIPE_PRICE_CREATOR_ANNUAL=price_...
# STRIPE_PRICE_SHOP_ANNUAL=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook URL: https://YOUR_DOMAIN/api/webhooks/stripe
# Events: checkout.session.completed, invoice.paid,
#         customer.subscription.deleted, customer.subscription.updated

# Development-only entitlement fallback is ./data/entitlements.json.
# Production billing and webhook idempotency require Supabase.

# Required before public Free exports are enabled. Point to a server ffmpeg
# binary that supports the drawtext filter.
# FFMPEG_PATH=/usr/bin/ffmpeg

# Force-enable dev plan upgrades even in production (not recommended)
# ALLOW_DEV_UPGRADE=1
