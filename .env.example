# --- Video generation (ByteDance Seedance via fal.ai) ---
# Get free signup credits: https://fal.ai/dashboard/keys
# Without FAL_KEY → DEMO mode (local /demos/* toy clips).
FAL_KEY=

# Wool / free trial path (cheapest): Mini @ ~$0.07/s 480p
# FAL_MODEL_FREE=bytedance/seedance-2.0/mini/image-to-video
# Paid default:
# FAL_MODEL=bytedance/seedance-2.0/image-to-video
# Optional paid-fast:
# FAL_MODEL_FAST=bytedance/seedance-2.0/fast/image-to-video

# --- Session / credits (signed cookie) ---
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# --- Supabase Auth + durable credits (T5) ---
# Project Settings → API. Publishable = anon; Secret service_role = server only.
# SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# Optional Google OAuth (after enabling in Supabase Providers):
# SUPABASE_AUTH_GOOGLE=1

# --- Site URL (magic-link redirect origin) ---
# Local default is http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://your-preview.vercel.app

# --- Stripe billing (test only until boss approves live) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_CREATOR=price_...
# STRIPE_PRICE_SHOP=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook URL: https://YOUR_DOMAIN/api/webhooks/stripe
# Soft launch: leave payments off
# NEXT_PUBLIC_PAYMENTS_ENABLED=0
# Never set PAYMENTS_LIVE=1 with sk_live without explicit boss approval
# PAYMENTS_LIVE=0

# Durable entitlements file (default: ./data/entitlements.json)
# ENTITLEMENTS_PATH=/var/data/entitlements.json

# Force durable path (requires writable store / Supabase schema)
# REQUIRE_DURABLE_CREDITS=0
# DURABLE_CREDITS=local

# Force-enable dev plan upgrades even in production (not recommended)
# ALLOW_DEV_UPGRADE=1
# Local: set ALLOW_DEV_UPGRADE=0 to test "Coming soon" paid buttons
# ALLOW_DEV_UPGRADE=0

# Local free-credit refill: POST /api/dev/topup (also on when NODE_ENV=development)
# PIKBO_DEV_TOPUP=1

# G6 refund automation only (never production):
# PIKBO_FORCE_GENERATE_FAIL=1

# Optional analytics (no-op if empty)
# NEXT_PUBLIC_ANALYTICS_URL=

# T6 file watermark bake — only after operator proves baked files exist
# PIKBO_T6_FILE_BAKE=0
